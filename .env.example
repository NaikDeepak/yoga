# ── Supabase Auth (keep these even when using Neon + R2) ──────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Database (Supabase default; replace with Neon URL to use Neon) ─────────────
DATABASE_URL=postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres
# Neon pooled:  postgresql://USER:PASS@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true

# ── File storage (leave blank to use Supabase Storage; fill all 4 for R2) ─────
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-api-token-key
# R2_SECRET_ACCESS_KEY=your-r2-api-token-secret
# R2_BUCKET=patient-files
GEMINI_API_KEY=